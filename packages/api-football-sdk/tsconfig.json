{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "isolatedModules": true,

    "resolveJsonModule": true,

    "lib": [
      "ES2022",
      "DOM"
    ],

    "outDir": "./dist",
    "rootDir": "src"
  },

  "include": ["src"]
}
